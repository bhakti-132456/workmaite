{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WorkmAIte",
  "version": "0.1.0",
  "identifier": "com.workmaite.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "WorkmAIte Pro",
        "width": 500,
        "height": 850,
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": true,
        "resizable": true,
        "minWidth": 360,
        "minHeight": 500
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/llama-server",
      "binaries/whisper-stt",
      "binaries/piper-tts"
    ],
    "resources": [
      "models/*",
      "binaries/**/*",
      "../core/*",
      "../deck/*"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "dialog": null
  }
}
